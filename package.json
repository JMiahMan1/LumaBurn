{
  "name": "lumaburn",
  "version": "0.2.2",
  "type": "module",
  "private": true,
  "description": "Browser-based laser job editor with ESP3D-aware device tooling.",
  "engines": {
    "node": ">=22"
  },
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "concurrently -k -s first \"node server.cjs\" \"wait-on http://127.0.0.1:4173 && node --test && node playwright_test.mjs\"",
    "test:unit": "node --test --experimental-test-coverage",
    "test:watch": "node --test --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "electron-builder",
    "package": "electron-builder --dir"
  },
  "build": {
    "appId": "com.lumaburn.app",
    "productName": "LumaBurn",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Graphics;Engineering;",
      "vendor": "LumaBurn",
      "synopsis": "Browser-based laser job editor with ESP3D-aware device tooling.",
      "executableName": "lumaburn"
    },
    "rpm": {
      "depends": [
        "libX11",
        "libXScrnSaver"
      ]
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.0.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "opentype.js": "^1.3.4"
  },
  "author": "LumaBurn Team <dev@lumaburn.app>",
  "license": "MIT",
  "homepage": "https://github.com/JMiahMan1/LumaBurn"
}
