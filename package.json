{
  "name": "lumaburn",
  "version": "0.2.0",
  "private": true,
  "description": "Browser-based laser job editor with ESP3D-aware device tooling.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "node scripts/build-packages.mjs",
    "package": "node scripts/build-packages.mjs"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "opentype.js": "^1.3.4"
  }
}
